{
  "appId": "com.silexperience.velohnav",
  "appName": "VelohNav",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "backgroundColor": "#080c0f",
    "allowMixedContent": false
  },
  "plugins": {
    "Geolocation": {
      "permissions": ["location"]
    },
    "CapacitorHttp": {
      "enabled": true
    }
  }
}
